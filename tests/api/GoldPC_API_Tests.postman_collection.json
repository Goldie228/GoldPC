		{
			"name": "PC Builder Service",
			"item": [
				{
					"name": "Check Compatibility - Valid Config",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Config is compatible\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.result.isCompatible).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"components\": [\n    { \"productId\": \"cpu-uuid\", \"category\": \"cpu\", \"specifications\": { \"socket\": \"AM5\" } },\n    { \"productId\": \"mb-uuid\", \"category\": \"motherboard\", \"specifications\": { \"socket\": \"AM5\" } }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{pcbuilder_url}}/api/v1/pcbuilder/check-compatibility",
							"host": [
