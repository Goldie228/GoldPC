{
  "request": {
    "method": "POST",
    "urlPath": "/api/v1/orders",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json"
      }
    }
  },
  "response": {
    "status": 201,
    "jsonBody": {
      "id": "{{randomValue type='UUID'}}",
      "orderNumber": "ORD-{{randomNumber length=5}}",
      "status": "New",
      "createdAt": "{{now}}"
    },
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"]
  }
}