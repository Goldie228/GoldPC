{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CatalogService": {
    "Url": "http://localhost:5000"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5005"
      }
    }
  },
  "Chaos": {
    "Enabled": false,
    "EnableRandomFailures": false,
    "FailureRate": 0.05,
    "EnableLatency": false,
    "LatencyRate": 0.1,
    "MinLatencyMs": 100,
    "MaxLatencyMs": 3000,
    "EnableServiceOutage": false,
    "OutageRate": 0.01,
    "RetryAfterSeconds": 30,
    "ExcludedPaths": [],
    "EnableLogging": true
  }
}
