# Frontend environment variables
# Copy to .env.local for local overrides (not committed)

# Использовать реальный API вместо MSW-моков (dev)
# true = запросы идут на CatalogService, false = MSW перехватывает
VITE_USE_REAL_API=false

# Базовый URL API (по умолчанию /api/v1 — проксируется на бэкенд)
# VITE_API_URL=/api/v1
