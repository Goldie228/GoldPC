{
  "forbidden": [
    {
      "name": "no-circular",
      "severity": "error",
      "from": {},
      "to": {
        "circular": true
      }
    },
    {
      "name": "no-ui-to-store",
      "severity": "error",
      "from": { "path": "^src/components/" },
      "to": { "path": "^src/store/" }
    },
    {
      "name": "no-api-in-pages",
      "severity": "error",
      "from": { "path": "^src/pages/" },
      "to": { "path": "^src/api/" }
    },
    {
      "name": "no-cross-feature",
      "severity": "error",
      "from": { "path": "^src/features/([^/]+)/" },
      "to": { "path": "^src/features/", "pathNot": "^src/features/$1/" }
    }
  ]
}