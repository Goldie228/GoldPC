# ==================================================
# GoldPC .gitignore
# ==================================================

# ==================================================
# SECRETS - NEVER COMMIT THESE
# ==================================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json
service-account.json

# ==================================================
# IDE and Editor
# ==================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ==================================================
# Node.js
# ==================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
.pnp.*
dist/
build/
.cache/
.parcel-cache/

# ==================================================
# .NET
# ==================================================
bin/
obj/
*.dll
*.pdb
*.exe
*.user
*.suo
*.cache
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc
_ReSharper*/
*.DotSettings
packages/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# ==================================================
# Test Coverage
# ==================================================
coverage/
.nyc_output/
*.coverage
*.coveragexml
TestResults/
*.trx

# ==================================================
# Mutation Testing (Stryker.NET)
# ==================================================
StrykerOutput/
mutation-report.json

# ==================================================
# Docker
# ==================================================
.docker/

# ==================================================
# Kubernetes
# ==================================================
*.kubeconfig
kubeconfig

# ==================================================
# Chrome DevTools / Playwright MCP
# ==================================================
.playwright-mcp/

# ==================================================
# Terraform
# ==================================================
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
.terraform.lock.hcl

# ==================================================
# Uploaded/Generated content
# ==================================================
src/CatalogService/uploads/*
!src/CatalogService/uploads/.gitkeep

# ==================================================
# Logs
# ==================================================
logs/
*.log
*.txt

# ==================================================
# OS Files
# ==================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==================================================
# Build outputs
# ==================================================
out/
target/
*.class
*.jar
*.war

# ==================================================
# Temporary files
# ==================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ==================================================
# Security scan reports
# ==================================================
*.sarif
snyk-*.json
trivy-*.json
semgrep-*.json
npm-audit.json
vulnerable-packages.json

# ==================================================
# Documentation builds
# ==================================================
site/
_site/

# Comparison audit reports (scripts/comparison-audit/run-comparison-audit.ts)
scripts/comparison-audit/out/
scripts/comparison-audit/audit-notes/

*.turbo/
*.cursor/

# ==================================================
# AI/Agent Tools
# ==================================================
# Claude Code
.claude/

# Cursor IDE
.cursor/

# Cline
.cline/

# Serena
.serena/

# Generic agents directory
.agents/

# Playwright MCP
.playwright-mcp/

# RAG store
.rag-store/
*.rag-store/

# Virtual environments for MCP/RAG
.venv-lightrag/
.venv-mcp/

# MCP Lightrag scripts
mcp_lightrag/

# Skills lock file
skills-lock.json

# Project temp files
project/

# Git worktrees
worktrees/

# ==================================================
# Test Artifacts
# ==================================================
# Playwright test results
test-results/
test-screenshots/
*.last-run.json

# Dependency cruiser
.dependency-cruiser-frontend.json
.dependency-cruiser-frontend.js

# ==================================================
# Security Scanners (config files)
# ==================================================
.snyk
.semgrep.yml

# ==================================================
# MCP and SQLite databases
# ==================================================
.mcp.json
.mcp-sqlite.db
sqlite_mcp_server.db

# ==================================================
# Debug/Temp Files (root only)
# ==================================================
# Screenshots in root
/*.png
/*.jpg
/*.jpeg
/*.gif

# YAML state dumps in root
/*.yml
/*.yaml

# Test scripts in root
/*.mjs

# Git logs
.git-log-tmp.txt

# Docker test compose
docker-compose.test.yml

# SQL backups in root
/*.sql

# Docker install scripts
get-docker.sh

# Word docs
*.doc
*.docx

# AI process docs in root
/AI_*.md
/AI_*.mmd
