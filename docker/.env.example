# =============================================================================
# Environment Variables for GoldPC Docker Compose
# =============================================================================
# Copy this file to .env and fill in the values.
# cp .env.example .env
#
# Dev compose uses defaults from this file for local development.
# Prod compose requires ALL variables to be set (no defaults).
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev_password

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest_dev_password

# ── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-at-least-32-characters-long
SMTP_PASSWORD=your-smtp-password

# ── Production-only (no defaults) ───────────────────────────────────────────
# DB_USER=postgres
# DB_PASSWORD=
# JWT_KEY=
# JWT_ISSUER=goldpc
# JWT_AUDIENCE=goldpc-users
# GRAFANA_ADMIN=admin
# GRAFANA_PASSWORD=

# ── Docker Image Settings ───────────────────────────────────────────────────
# IMAGE_VERSION=latest
# REGISTRY=ghcr.io
# IMAGE_PREFIX=goldpc
