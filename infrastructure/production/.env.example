# =============================================================================
# GoldPC Production Environment Variables
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in the values
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# REGISTRY CONFIGURATION
# =============================================================================
# Docker registry for pulling images
REGISTRY=ghcr.io/goldpc

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL credentials
DB_USER=goldpc_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=goldpc

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis password (leave empty if no authentication required)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT secret key (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_KEY=CHANGE_ME_GENERATE_A_SECURE_JWT_KEY_MIN_32_CHARS

# JWT issuer and audience
JWT_ISSUER=goldpc
JWT_AUDIENCE=goldpc-users

# Token expiration times
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION=7

# =============================================================================
# VERSION TAGS FOR BLUE-GREEN DEPLOYMENT
# =============================================================================
# Current stable version (Blue)
BLUE_VERSION=v1.0.0

# New version for deployment (Green)
GREEN_VERSION=v1.1.0

# Frontend version
FRONTEND_VERSION=v1.0.0

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base URL for API
API_BASE_URL=https://goldpc.by

# =============================================================================
# SSL/TLS CERTIFICATES
# =============================================================================
# Certificate paths are configured in nginx.conf
# Place certificates in nginx/ssl/ directory:
# - goldpc.by.crt (SSL certificate)
# - goldpc.by.key (SSL private key)
# =============================================================================

# =============================================================================
# MONITORING (Optional)
# =============================================================================
# Prometheus metrics endpoint (if enabled)
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Grafana admin password (if monitoring stack is deployed)
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# =============================================================================
# ALERTING (Optional)
# =============================================================================
# Slack webhook URL for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email alerting
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@goldpc.by
# SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
# ALERT_EMAIL=ops@goldpc.by