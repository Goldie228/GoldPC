{
  "dashboard": {
    "id": null,
    "uid": "goldpc-overview",
    "title": "GoldPC Overview",
    "tags": ["goldpc", "microservices"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "type": "row",
        "title": "Pod Status",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
      },
      {
        "id": 1,
        "type": "stat",
        "title": "Running Pods",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{phase=\"Running\"})",
            "refId": "A"
          }
        ]
      },
      {
        "type": "row",
        "title": "Resource Usage",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "CPU Usage (per pod)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Memory Usage (per pod)",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{image!=\"\"}",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ]
      },
      {
        "type": "row",
        "title": "Logs (Loki)",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
      },
      {
        "id": 4,
        "type": "logs",
        "title": "Application Logs",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
        "targets": [
          {
            "expr": "{namespace=~\"staging|production\"}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
