{
  "name": "xcore-scraper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Парсер товаров X-Core.by для учебного проекта GoldPC",
  "scripts": {
    "scrape": "node index.mjs",
    "scrape:all": "node index.mjs --all",
    "scrape:gpu-ram-coolers": "node index.mjs --categories=gpu,ram,coolers --slow",
    "fetch-images": "node fetch-product-images.mjs",
    "fetch-images:test": "node fetch-product-images.mjs --limit=10",
    "fetch-images:ram-coolers": "node fetch-product-images.mjs --categories=ram,coolers",
    "sync-with-images": "node sync-products-with-images.mjs",
    "remap-periphery": "node remap-periphery-to-mice-keyboards.mjs",
    "parse-specs-html": "node parse-specs-from-html.mjs",
    "parse-specs-html:test": "node parse-specs-from-html.mjs --test",
    "parse-specs-html:retry": "node parse-specs-from-html.mjs --category=psu --only-empty --slow",
    "audit-filters": "node fetch-xcore-filters.mjs",
    "audit-filters:gpu": "node fetch-xcore-filters.mjs --category=gpu",
    "download-images": "node download-images.mjs",
    "download-images:test": "node download-images.mjs --limit=20",
    "verify-local-images": "node verify-local-images.mjs"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "pg": "^8.11.0"
  }
}
